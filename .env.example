# Supabase PostgreSQL connection string (Settings > Database > URI)
# Use the "Transaction pooler" URL for serverless/external connections.
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Backend (Render) - PORT is set automatically by Render
PORT=8080
NODE_ENV=production

# Frontend build (Vercel) - optional, defaults shown
BASE_PATH=/
PORT=3000
