# Supabase PostgreSQL connection string (Settings > Database > URI)
# Use the "Transaction pooler" URL for serverless/external connections.
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Production: set a different DATABASE_URL on each Render service
# (kanji-trainer-api-cv vs kanji-trainer-api-personal). See DEPLOY.md.

# Local dev only (pnpm dev from project root — gitignored .env, not used by Render/Vercel)
BACKEND_PORT=8080
FRONTEND_PORT=3000
BASE_PATH=/

# One-time: assign all existing DB rows to owner user (default id=1)
# pnpm db:assign-owner
# OWNER_USER_ID=1 pnpm db:assign-owner
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=change-me-min-8-chars

# CORS + password reset links — comma-separated, no trailing slashes
# Local + both Vercel sites (set per Render service):
# FRONTEND_ORIGINS=http://localhost:3000,https://kanji-trainer-five.vercel.app
# CV Render: FRONTEND_ORIGINS=http://localhost:3000,https://kanji-trainer-cv-two.vercel.app
FRONTEND_ORIGINS=http://localhost:3000

# SMTP (optional — without these, reset links are logged to the backend console)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=Kanji Trainer <noreply@yourdomain.com>

# Production (Vercel): set per project — Render backend origin, no trailing slash.
# Personal: VITE_API_ORIGIN=https://kanji-trainer.onrender.com
# CV:       VITE_API_ORIGIN=https://kanji-trainer-api-cv.onrender.com
# Leave unset locally; Vite proxies /api to localhost:8080.

# Production: Render sets PORT automatically in the dashboard.
